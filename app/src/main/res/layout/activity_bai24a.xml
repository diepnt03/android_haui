<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".bai2.bai24a">

    <TextView
        android:id="@+id/tv_title"
        android:textColor="@color/white"
        android:background="@color/purple"
        android:textStyle="bold"
        android:textSize="25dp"
        android:padding="20dp"
        android:text="Lưu trữ với_SharedPreferences"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:layout_marginTop="10dp"
        android:layout_below="@+id/tv_title"
        android:orientation="horizontal"
        android:id="@+id/ll_username"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:layout_marginEnd="5dp"
            android:textSize="20sp"
            android:text="Ten dang nhap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <EditText
            android:hint="Name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <LinearLayout
        android:layout_marginTop="10dp"
        android:layout_below="@+id/ll_username"
        android:orientation="horizontal"
        android:id="@+id/ll_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:layout_marginEnd="5dp"
            android:textSize="20sp"
            android:text="Mat khau"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <EditText
            android:hint="pass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <CheckBox
        android:id="@+id/cb_save_inf"
        android:layout_marginTop="10dp"
        android:textSize="20sp"
        android:text="Luu thong tin"
        android:layout_below="@id/ll_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:layout_marginTop="10dp"
        android:layout_below="@id/cb_save_inf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="@color/grey"
            android:text="Nhap"
            android:textStyle="bold" />

        <Button
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="@color/grey"
            android:text="Thoat"
            android:textStyle="bold" />

    </LinearLayout>

</RelativeLayout>